# .env.example — 复制为 .env 并填写真实值，不要提交 .env 到 git

# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_TOKEN=your_bot_token_here

# 你的 Telegram 用户 ID（从 @userinfobot 获取）
ALLOWED_USER_ID=123456789

# Telegram 群组 ID（开启 Topics 的超级群组，从 @getidsbot 获取，负数）
GROUP_CHAT_ID=-1001234567890

# Claude 可选配置：
# - 官方 Claude CLI 登录链路可留空，先执行 `claude auth login`
# - 代理或 gateway 链路可填写 base_url 和 model
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
