{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OnlineWorker",
  "version": "1.0.0",
  "identifier": "com.wxy.onlineworker-app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OnlineWorker",
        "width": 960,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' ipc: https://api.tauri.app"
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "resources": [
      "provider-plugins",
      "icons/tray-template.png",
      "icons/tray-template@2x.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "externalBin": ["binaries/onlineworker-bot"]
  }
}
