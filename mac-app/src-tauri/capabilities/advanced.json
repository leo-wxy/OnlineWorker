{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "advanced",
  "description": "Extended capability for advanced operations - use with caution",
  "windows": ["advanced"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:event:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "$APPDATA/*"
        },
        {
          "path": "$HOME/.codex/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$APPDATA/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        {
          "path": "$APPDATA"
        },
        {
          "path": "$HOME/.codex/rollouts"
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "open-terminal",
          "cmd": "open",
          "args": ["-a", "Terminal", { "validator": ".*" }],
          "sidecar": false
        },
        {
          "name": "launchctl",
          "cmd": "launchctl",
          "args": true,
          "sidecar": false
        },
        {
          "name": "get-uid",
          "cmd": "id",
          "args": ["-u"],
          "sidecar": false
        }
      ]
    }
  ]
}
