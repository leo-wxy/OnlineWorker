{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for app windows - restricted permissions",
  "windows": ["main", "menubar-popover"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:event:default",
    "window-state:default"
  ]
}
