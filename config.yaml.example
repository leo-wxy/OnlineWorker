# OnlineWorker configuration template.
# Main Telegram bot credentials remain in .env; notification plugin settings live below.

schema_version: 2

providers:
  codex:
    visible: true
    managed: true
    autostart: true
    runtime_id: codex
    bin: "codex"
    owner_transport: "unix"
    live_transport: "shared_unix"
    control_mode: "app"
    transport:
      type: "unix"
    message_hooks:
      abusive_language_normalization:
        enabled: true

  claude:
    visible: true
    managed: false
    autostart: false
    runtime_id: claude
    bin: "claude"
    owner_transport: "stdio"
    live_transport: "stdio"
    control_mode: "app"
    transport:
      type: "stdio"
    message_hooks:
      abusive_language_normalization:
        enabled: false

telegram:
  # true = delete archived thread topics.
  # false = close topics and keep history visible in Telegram.
  delete_archived_topics: true
  # Keep true so Telegram requests can use HTTPS_PROXY/ALL_PROXY from the process environment.
  trust_env: true
  # Optional explicit proxy for Telegram, for example "socks5://127.0.0.1:7890".
  proxy_url: ""

logging:
  # DEBUG / INFO / WARNING / ERROR
  level: "INFO"

notifications:
  channels:
    telegram:
      enabled: true
      config:
        bot_token: ""
        recipient_user_id: ""
