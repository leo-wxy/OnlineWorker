# OnlineWorker configuration template.
# Main Telegram bot credentials remain in .env; notification plugin settings live below.

schema_version: 2

providers:
  codex:
    visible: true
    managed: true
    autostart: true
    runtime_id: codex
    bin: "codex"
    owner_transport: "stdio"
    live_transport: "owner_bridge"
    control_mode: "app"
    transport:
      type: "stdio"

  claude:
    visible: true
    managed: false
    autostart: false
    runtime_id: claude
    bin: "claude"
    owner_transport: "stdio"
    live_transport: "stdio"
    control_mode: "app"
    transport:
      type: "stdio"

telegram:
  # true = delete archived thread topics.
  # false = close topics and keep history visible in Telegram.
  delete_archived_topics: true

logging:
  # DEBUG / INFO / WARNING / ERROR
  level: "INFO"

notifications:
  channels:
    telegram:
      enabled: true
      config:
        bot_token: ""
        recipient_user_id: ""
